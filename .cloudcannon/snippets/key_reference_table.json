{
  "key_reference_table": {
    "snippet": "<comp.KeyReferenceTable>[[table_entries]]</comp.KeyReferenceTable>",
    "inline": false,
    "preview": {
      "icon": "key",
      "text": "Key Reference Table"
    },
    "_inputs": {
      "key": {
        "type": "select",
        "options": {
          "values": "collections.keys",
          "preview": {
            "text": {
              "key": "key_name"
            }
          }
        }
      },
      "table_entries": {
        "type": "array",
        "options": {
          "preview": {
            "text": {
              "key": "key.key_name"
            }
          }
        }
      }
    },
    "params": {
      "table_entries": {
        "parser": "repeating",
        "options": {
          "editor_key": "table_entries",
          "snippet": "<comp.KeyReferenceTableRow [[row_args]] />",
          "style": {
            "output": "block",
            "between": "\n",
            "block": {
              "leading": "\n",
              "trailing": "\n",
              "indent": "  "
            }
          }
        }
      },
      "row_args": {
        "parser": "key_values",
        "options": {
          "models": [
            {
              "editor_key": "key",
              "type": "string",
              "optional": false
            }
          ],
          "format": {
            "ref": "mdx_format"
          }
        }
      }
    }
  }
}
