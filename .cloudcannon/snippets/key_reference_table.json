{
  "key_reference_table": {
    "snippet": "<comp.KeyReferenceTable>[[rows]]</comp.KeyReferenceTable>",
    "inline": false,
    "preview": {
      "text": "Key Reference Table",
      "icon": "key"
    },
    "_inputs": {
      "key": {
        "type": "select",
        "options": {
          "values": "collections._keys",
        "preview": {
          "text": {
            "key": "key_name"
          }
        }
      }
    },
    "params": {
      "rows": {
        "parser": "repeating",
        "options": {
          "editor_key": "rows",
          "snippet": "<comp.KeyReferenceTableRow [[row_args]]>[[content]]</comp.KeyReferenceTableRow>",
          "style": {
            "output": "block",
            "between": "\n",
            "block": {
              "leading": "\n",
              "trailing": "\n",
              "indent": "  "
            }
          }
        }
      },
      "row_args": {
        "parser": "key_values",
        "options": {
          "models": [
            {
              "editor_key": "key",
              "type": "string",
              "optional": false,
              "remove_empty": true
            },
            {
              "editor_key": "label",
              "type": "string",
              "optional": true,
              "default": ""
            },
            {
              "editor_key": "type_markdown",
              "type": "string",
              "optional": true,
              "default": ""
            }
          ],
          "format": {
            "ref": "mdx_format"
          }
        }
      },
      "content": {
        "parser": "content",
        "options": {
          "editor_key": "inner_markdown",
          "allow_nested": true,
          "style": {
            "output": "block",
            "block": {
              "leading": "\n",
              "trailing": "\n",
              "indent": "  "
            }
          }
        }
      }
    }
  }
}
