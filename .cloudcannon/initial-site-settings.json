{
  "ssg": "lume",
  "mode": "hosted",
  "build": {
    "hugoVersion": "0.128.1",
    "rubyVersion": "2.7.3",
    "nodeVersion": "18",
    "denoVersion": "file",
    "preserved_paths": "_cc_vendor",
    "environment_variables": [
      {
        "key": "DENO_DIR",
        "value": "_cc_vendor"
      }
    ],
    "install_command": "",
    "build_command": "deno task build",
    "output_path": "_site",
    "preserveOutput": false,
    "includeGit": true,
    "use_beta_plugin": false
  }
}